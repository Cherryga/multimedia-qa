## Copy this file to ".env" and fill in values.
## IMPORTANT: Do NOT commit your real secrets.

# Required for real Groq-powered summaries/Q&A/transcription
OPENAI_API_KEY=

# Optional overrides
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_CHAT_MODEL=llama-3.3-70b-versatile
OPENAI_TRANSCRIPTION_MODEL=whisper-large-v3
